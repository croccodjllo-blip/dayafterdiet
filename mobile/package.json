{
  "name": "dayafterdiet-mobile",
  "version": "1.1.0",
  "private": true,
  "description": "Android wrapper (Capacitor) for DaD on Google Play",
  "scripts": {
    "setup": "npm install && npx cap add android",
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "build:debug": "cd android && ./gradlew assembleDebug",
    "build:release": "cd android && ./gradlew bundleRelease",
    "build:play": "bash build-play-release.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
