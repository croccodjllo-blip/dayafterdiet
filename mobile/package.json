{
  "name": "dayafterdiet-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Android wrapper (Capacitor) for DaD on Google Play",
  "scripts": {
    "setup": "npm install && npx cap add android",
    "sync": "npx cap sync android",
    "open": "npx cap open android",
    "build:debug": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0"
  }
}
