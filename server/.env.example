# Copia in .env e compila con le chiavi da https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID del piano mensile DaD (€4,99/mese) creato in Stripe Dashboard → Products
STRIPE_PRICE_ID=price_...

# Abilita Google Pay in Stripe Dashboard → Impostazioni → Metodi di pagamento
# Registra il dominio in Dashboard → Domini metodi di pagamento (o avvia il server: lo fa in automatico)

# URL pubblico del frontend (senza slash finale)
# Locale: http://localhost:5500
# GitHub Pages: https://TUO-UTENTE.github.io/dayafterdiet
FRONTEND_URL=http://localhost:5500

# Porta del server API
PORT=4242
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
FRONTEND_URL=https://croccodjllo-blip.github.io/dayafterdiet
