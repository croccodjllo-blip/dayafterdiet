# Copia in .env e compila con le chiavi da https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID del piano mensile DaD (€4,99/mese) creato in Stripe Dashboard → Products
STRIPE_PRICE_ID=price_...

# URL pubblico del frontend (senza slash finale)
FRONTEND_URL=http://localhost:5500

# Porta del server API
PORT=4242
